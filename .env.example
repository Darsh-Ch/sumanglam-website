# --- Database (PostgreSQL via Prisma) ------------------------------------
# Supabase session pooler (dev/long-running): append ?connection_limit=4&pool_timeout=20
# Supabase transaction pooler (serverless/Vercel, port 6543): append ?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://USER:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres?connection_limit=4&pool_timeout=20"

# --- Auth.js (admin authentication) ---------------------------------------
# Generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET=""
# Placeholder single-admin credentials until a real provider is configured.
ADMIN_EMAIL="admin@sumanglam.co"
# bcrypt-free placeholder: plain value compared in the credentials provider.
# Replace with a real hashed-credential or OAuth setup before production.
ADMIN_PASSWORD=""

# --- Cloudinary (asset delivery) ------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- Google Analytics 4 ----------------------------------------------------
NEXT_PUBLIC_GA4_MEASUREMENT_ID=""

# --- Business contact (placeholders until confirmed) ------------------------
# WhatsApp number in international format without "+", e.g. 919999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=""
NEXT_PUBLIC_CONTACT_PHONE=""
NEXT_PUBLIC_CONTACT_EMAIL=""

# --- Site ------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
